{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/chat" },
    { "source": "/api/upload", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/upload" },
    { "source": "/api/health", "destination": "https://f1-omnisense-backend-production.up.railway.app/health" },
    { "source": "/api/3d-gen/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/3d-gen/:path" },
    { "source": "/api/visual-search", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/visual-search" },
    { "source": "/api/visual-tags", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/visual-tags" },
    { "source": "/3d-models/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/3d-models/:path" },
    { "source": "/api/f1data/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/f1data/:path" },
    { "source": "/api/mccar/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mccar/:path" },
    { "source": "/api/mcdriver/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mcdriver/:path" },
    { "source": "/api/mcracecontext/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mcracecontext/:path" },
    { "source": "/api/mccar-summary/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mccar-summary/:path" },
    { "source": "/api/mccar-race-telemetry/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mccar-race-telemetry/:path" },
    { "source": "/api/mccar-race-stints/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mccar-race-stints/:path" },
    { "source": "/api/mcdriver-summary/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mcdriver-summary/:path" },
    { "source": "/models/:file(.*\\.glb)", "destination": "/api/models?file=:file" },
    { "source": "/api/openf1/:endpoint(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/openf1/:endpoint" },
    { "source": "/api/driver_intel/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/driver_intel/:path" },
    { "source": "/api/opponents/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/opponents/:path" },
    { "source": "/api/jolpica/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/jolpica/:path" },
    { "source": "/api/pipeline/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/pipeline/:path" },
    { "source": "/api/circuit_intel/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/circuit_intel/:path" },
    { "source": "/api/omni/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/omni/:path" },
    { "source": "/api/updater/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/updater/:path" },
    { "source": "/api/fleet-vehicles", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/fleet-vehicles" },
    { "source": "/api/constructor_profiles/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/constructor_profiles/:path" },
    { "source": "/api/constructor_profiles", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/constructor_profiles" },
    { "source": "/api/advantage/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/advantage/:path" },
    { "source": "/api/radio/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/radio/:path" },
    { "source": "/api/strategy/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/strategy/:path" },
    { "source": "/api/backtest/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/backtest/:path" },
    { "source": "/api/automl/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/automl/:path" },
    { "source": "/api/anomaly/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/anomaly/:path" },
    { "source": "/api/forecast/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/forecast/:path" },
    { "source": "/media/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/media/:path" },
    { "source": "/api/mccar-telemetry/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mccar-telemetry/:path" },
    { "source": "/api/mclaren/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/mclaren/:path" },
    { "source": "/api/victory/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/victory/:path" },
    { "source": "/api/fleet/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/fleet/:path" },
    { "source": "/api/aim/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/aim/:path" },
    { "source": "/api/local/:path(.*)", "destination": "https://f1-omnisense-backend-production.up.railway.app/api/local/:path" }
  ],
  "headers": [
    {
      "source": "/circuits/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
